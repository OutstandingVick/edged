# Google Gemini — get free key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Polymarket (read-only market data is FREE, no key needed)
# Only needed for live order execution:
POLYMARKET_API_KEY=
POLYMARKET_WALLET_PRIVATE_KEY=

# Circle developer-controlled wallet on Arc Testnet
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_registered_entity_secret_here
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=

# Required only when PAPER_TRADING=false
CIRCLE_USDC_TOKEN_ID=
CIRCLE_ESCROW_ADDRESS=

# Agent settings
PAPER_TRADING=true
BANKROLL=100
MAX_BET_FRACTION=0.05
MIN_EDGE=0.05

NEXT_PUBLIC_APP_URL=http://localhost:3000
